# Prevent any uploaded file from ever being executed as a script,
# and stop people from browsing a directory listing of all uploads.

<FilesMatch "\.(php|phtml|php\d|pl|py|cgi|asp|sh)$">
	<IfModule mod_authz_core.c>
		Require all denied
	</IfModule>
	<IfModule !mod_authz_core.c>
		Order allow,deny
		Deny from all
	</IfModule>
</FilesMatch>

Options -Indexes
